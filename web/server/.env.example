# Copy to .env — never commit .env
#
# --- Your setup (SSMS / Azure Data Studio screenshot) ---
# Server: localhost\SQLEXPRESS01
# Authentication: Windows
# Encrypt: Mandatory, Trust server certificate: ON
#
# Windows Auth (same user as runs `npm run dev` — e.g. OMEN-15\usher):
SQL_USE_WINDOWS_AUTH=true

# Option A — same string as SSMS "Server name" (one backslash before the instance).
# Named instance without SQL_PORT: start "SQL Server Browser" unless you use TCP + SQL_PORT below.
SQL_SERVER_FULL=localhost\SQLEXPRESS01

# Option B — host + instance (omit SQL_SERVER_FULL when using this):
# SQL_SERVER=localhost
# SQL_INSTANCE=SQLEXPRESS01

# TCP (omit SQL_SERVER_FULL when using explicit host:port). 127.0.0.1 avoids IPv6 localhost issues:
# SQL_SERVER=127.0.0.1
# SQL_PORT=49217
#
# If you get "ETIMEOUT" on named instance: SQL Server Browser off or UDP blocked — enable Browser
# or set SQL_PORT from Configuration Manager → TCP/IP → IPAll (dynamic or static).

SQL_CONNECTION_TIMEOUT_MS=60000
SQL_DATABASE=AshcolInventory

SQL_ENCRYPT=true
SQL_TRUST_SERVER_CERTIFICATE=true

# --- Alternative: SQL Server authentication (sa or app login) ---
# SQL_USE_WINDOWS_AUTH=false
# SQL_SERVER=localhost
# SQL_PORT=1433
# SQL_USER=sa
# SQL_PASSWORD=your_password

PORT=3001
CORS_ORIGIN=http://localhost:5174
